[
  {
    "context": "Editor && vim_mode == normal && !menu",
    "use_key_equivalents": true,
    "bindings": {
      "ctrl-h": "pane::ActivatePreviousItem",
      "ctrl-l": "pane::ActivateNextItem",
      "ctrl-x": "pane::CloseActiveItem",

      "t": "project_panel::ToggleFocus",

      "enter": "vim::ClearOperator",

      ", p": "file_finder::Toggle",
      ", ?": "workspace::OpenRecent",
      ", /": "buffer_search::Deploy",
      ", s b": "tab_switcher::Toggle",
      ", k": ["workspace::SendKeystrokes", "shift-cmd-f"],
      ", shift-k": ["workspace::SendKeystrokes", "shift-cmd-f"],

      ", c": "editor::ToggleComments",

      ", x x": "diagnostics::Deploy",
      ", x l": "diagnostics::Deploy",

      ", c c": "agent::ToggleFocus",
      ", c a": "agent::ToggleFocus",
      ", c d": "git::StageAndNext",
      ", c x": "git::UnstageAndNext",

      ", b": "debugger::ToggleBreakpoint",
      ", v s": "task::Spawn",
      ", l g": "task::Spawn",
      ", l a": "task::Spawn",

      "f5": "debugger::Continue",
      "f10": "debugger::StepOver",
      "f11": "debugger::StepInto",
      "f12": "debugger::StepOut",

      "g a": "editor::ToggleCodeActions",
      "g d": "editor::GoToDefinition",
      "shift-g shift-d": "editor::GoToDeclaration",
      "g i": "editor::GoToImplementation",
      "g r": "editor::FindAllReferences",
      "g e": "editor::GoToDiagnostic",
      "shift-g shift-e": "editor::GoToPreviousDiagnostic",
      "g l": "editor::Hover",
      "shift-h": "editor::Hover"
    }
  },
  {
    "context": "Editor && vim_mode == visual",
    "use_key_equivalents": true,
    "bindings": {
      ", c": "editor::ToggleComments",
      ", c s": "agent::QuoteSelection",
      ", k": "pane::DeploySearch"
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "ctrl-k": "editor::ShowSignatureHelp",
      "ctrl-space": "editor::ShowCompletions"
    }
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "t": "project_panel::ToggleFocus"
    }
  }
]
